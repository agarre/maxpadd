<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
    <class>MaxpaddConfig</class>
    <widget class="QWidget" name="MaxpaddConfig">
        <layout class="QVBoxLayout" name="mainLayout">
            <item>
                <widget class="QTabWidget" name="tabWidget">

                    <!-- Tab 1: Padding -->
                    <widget class="QWidget" name="tabPadding">
                        <attribute name="title">
                            <string>Padding</string>
                        </attribute>
                        <layout class="QVBoxLayout" name="paddingLayout">
                            <item>
                                <widget class="QLabel" name="labelDescription">
                                    <property name="text">
                                        <string>Gap size in pixels, applied equally on all four sides of the window.</string>
                                    </property>
                                    <property name="wordWrap">
                                        <bool>true</bool>
                                    </property>
                                </widget>
                            </item>
                            <item>
                                <layout class="QFormLayout" name="paddingForm">
                                    <item row="0" column="0">
                                        <widget class="QLabel" name="labelGap">
                                            <property name="text">
                                                <string>Gap size:</string>
                                            </property>
                                        </widget>
                                    </item>
                                    <item row="0" column="1">
                                        <widget class="QSpinBox" name="kcfg_gapSize">
                                            <property name="toolTip">
                                                <string>Space between the window edge and the screen edge, in pixels. 0 = no gap (normal maximize).</string>
                                            </property>
                                            <property name="minimum">
                                                <number>0</number>
                                            </property>
                                            <property name="maximum">
                                                <number>200</number>
                                            </property>
                                            <property name="value">
                                                <number>15</number>
                                            </property>
                                            <property name="suffix">
                                                <string> px</string>
                                            </property>
                                        </widget>
                                    </item>
                                </layout>
                            </item>
                            <item>
                                <spacer name="paddingSpacer">
                                    <property name="orientation">
                                        <enum>Qt::Vertical</enum>
                                    </property>
                                </spacer>
                            </item>
                        </layout>
                    </widget>

                    <!-- Tab 2: Ignored Apps -->
                    <widget class="QWidget" name="tabIgnored">
                        <attribute name="title">
                            <string>Ignored Apps</string>
                        </attribute>
                        <layout class="QVBoxLayout" name="ignoredLayout">
                            <item>
                                <widget class="QLabel" name="labelIgnoredInfo">
                                    <property name="text">
                                        <string>These apps are always ignored: plasmashell, krunner, spectacle, polkit-kde-authentication-agent-1, kscreen_osd_service, ksplashqml, ksmserver, xdg-desktop-portal-kde.

Add extra apps below (comma-separated). Use the app's window class name (e.g. "discord", "steam").</string>
                                    </property>
                                    <property name="wordWrap">
                                        <bool>true</bool>
                                    </property>
                                </widget>
                            </item>
                            <item>
                                <layout class="QFormLayout" name="ignoredForm">
                                    <item row="0" column="0">
                                        <widget class="QLabel" name="labelIgnoredApps">
                                            <property name="text">
                                                <string>Extra ignored apps:</string>
                                            </property>
                                        </widget>
                                    </item>
                                    <item row="0" column="1">
                                        <widget class="QLineEdit" name="kcfg_ignoredApps">
                                            <property name="placeholderText">
                                                <string>e.g. discord, steam, gimp</string>
                                            </property>
                                            <property name="toolTip">
                                                <string>Comma-separated list of window class names to exclude from padding.</string>
                                            </property>
                                        </widget>
                                    </item>
                                </layout>
                            </item>
                            <item>
                                <spacer name="ignoredSpacer">
                                    <property name="orientation">
                                        <enum>Qt::Vertical</enum>
                                    </property>
                                </spacer>
                            </item>
                        </layout>
                    </widget>

                </widget>
            </item>
        </layout>
    </widget>
</ui>
